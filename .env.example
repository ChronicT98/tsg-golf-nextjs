# NextAuth Configuration
NEXTAUTH_URL=https://your-domain.vercel.app
NEXTAUTH_SECRET=your-nextauth-secret-key

# Admin Credentials
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-admin-password

# Vercel Blob Configuration
BLOB_READ_WRITE_TOKEN=your-blob-read-write-token

# Note: When deploying to Vercel:
# 1. Set a strong NEXTAUTH_SECRET (you can generate one with: openssl rand -base64 32)
# 2. Set secure admin credentials (ADMIN_USERNAME and ADMIN_PASSWORD)
# 3. Create a new Blob store in your Vercel project and set BLOB_READ_WRITE_TOKEN
# 4. Vercel will automatically set the NEXTAUTH_URL in production